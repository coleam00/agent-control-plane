# Neon serverless Postgres connection string (pooled is fine).
# Get it from the Neon console: Project > Connection Details > "Pooled connection".
DATABASE_URL=postgres://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require

# Pi (the provider-independent coding agent) settings.
# PI_BIN: the pi binary. Defaults to "pi" on PATH. On Windows set the full path
# if "pi" does not resolve (e.g. C:\Users\you\AppData\Roaming\npm\pi.cmd).
PI_BIN=pi
# Model ref as <provider>/<model>. Pi resolves the provider from your pi auth,
# so this can be ANY model Pi supports (Claude, GPT, Gemini, Kimi, local, ...).
# Examples (run `pi` then /model to see the exact ids your auth exposes):
#   PI_MODEL=anthropic/claude-sonnet-4     (Claude; ANTHROPIC_API_KEY or pi /login)
#   PI_MODEL=openai/gpt-4o                  (OpenAI; OPENAI_API_KEY or pi /login)
#   PI_MODEL=google/gemini-2.5-pro          (Gemini; GEMINI_API_KEY)
#   PI_MODEL=ollama/llama3.1:8b             (local; via ~/.pi/agent/models.json)
PI_MODEL=kimi-coding/kimi-for-coding
# Tools the loop agent may use while building. read,bash,edit,write is the
# standard coding set. Comma-separated.
PI_TOOLS=read,bash,edit,write
# Optional: path to a Pi safety extension (.ts) loaded with -e when bash/edit/
# write are enabled. Leave unset to run without it.
# PI_SAFETY_EXT=/path/to/pi_safety.ts
# Hard wall-clock cap per single Pi run, in seconds (a runaway-loop backstop).
PI_RUN_TIMEOUT_S=900

# Backend HTTP port.
PORT=8787

# Where loop agents do their work (one subdir per loop). Relative to backend/.
WORKSPACES_DIR=workspaces
